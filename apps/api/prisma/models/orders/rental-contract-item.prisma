model RentalContractItem {
  id String @id @default(uuid())

  organizationId String

  rentalContractId String
  rentalContract   RentalContract @relation(fields: [rentalContractId, organizationId], references: [id, organizationId], onDelete: Restrict)

  // 원 주문 항목 (가격, 제품 정보 참조)
  rentalOrderItemId String?
  rentalOrderItem   RentalOrderItem? @relation(fields: [rentalOrderItemId, organizationId], references: [id, organizationId], onDelete: Restrict)

  assetId String
  asset   Asset  @relation(fields: [assetId, organizationId], references: [id, organizationId], onDelete: Restrict)

  status RentalContractItemStatus @default(PENDING)

  // 활성화 시점에 RentalOrderItem.monthlyRentalPrice를 복사해 보관
  monthlyRentalPrice Int

  startedAt  DateTime?
  endedAt    DateTime?
  returnedAt DateTime?

  // 카운터 과금 설정 (billingType = METER일 때 사용)
  billingType    BillingType @default(FIXED)
  freeBlackCount Int? // 무료 흑백 매수
  blackUnitPrice Int? // 흑백 초과 단가
  freeColorCount Int? // 무료 컬러 매수
  colorUnitPrice Int? // 컬러 초과 단가

  // 설치 주소 (Address 모델 1:1 제약 충돌로 비정규화)
  installationZonecode      String?
  installationAddress       String?
  installationAddressDetail String?

  // 교체된 경우: 이 항목을 교체한 새 항목
  replacedByItemId String?
  replacedByItem   RentalContractItem?  @relation("ItemReplacement", fields: [replacedByItemId, organizationId], references: [id, organizationId], onDelete: Restrict)
  replacedItems    RentalContractItem[] @relation("ItemReplacement")
  replacedAt       DateTime?

  invoiceItems InvoiceItem[]
  meterReadings MeterReading[]

  memo String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // assetId 기준 ACTIVE 항목은 1개만 가능
  // Prisma는 partial unique index를 지원하지 않으므로
  // migration SQL에 별도 추가: CREATE UNIQUE INDEX ON "RentalContractItem" ("assetId") WHERE status = 'ACTIVE'
  @@unique([id, organizationId])
  @@index([organizationId])
  @@index([organizationId, rentalContractId])
  @@index([organizationId, assetId])
  @@index([organizationId, status])
  @@index([organizationId, assetId, status])
  @@index([organizationId, replacedAt])
  @@index([organizationId, status, endedAt])
}
