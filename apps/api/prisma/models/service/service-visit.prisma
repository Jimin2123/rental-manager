model ServiceVisit {
  id String @id @default(uuid())

  organizationId String

  serviceRequestId String
  serviceRequest   ServiceRequest @relation(fields: [serviceRequestId, organizationId], references: [id, organizationId], onDelete: Restrict)

  // 담당 직원 (미배정 가능)
  staffId String?
  staff   OrganizationMember? @relation(fields: [staffId, organizationId], references: [id, organizationId], onDelete: Restrict)

  status ServiceVisitStatus @default(SCHEDULED)

  scheduledAt DateTime?
  visitedAt   DateTime?

  workDescription String?
  result          ServiceVisitResult?

  // 유상 AS 청구 근거 비용 (Invoice 생성 시 사용)
  laborCost  Int? // 공임비
  partsCost  Int? // 부품비
  travelCost Int? // 출장비

  requiresFollowUp Boolean @default(false)
  followUpNote     String?

  memo String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([organizationId])
  @@index([organizationId, serviceRequestId])
  @@index([organizationId, staffId])
  @@index([organizationId, status])
  @@index([organizationId, scheduledAt])
}
