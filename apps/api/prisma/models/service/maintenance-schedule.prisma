model MaintenanceSchedule {
  id String @id @default(uuid())

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Restrict)

  rentalContractId String
  rentalContract   RentalContract @relation(fields: [rentalContractId, organizationId], references: [id, organizationId], onDelete: Restrict)

  // 점검 주기
  intervalUnit  MaintenanceIntervalUnit
  intervalValue Int // 예: 3 (MONTH) → 3개월마다, 90 (DAY) → 90일마다

  // 점검 일정
  nextScheduledAt DateTime  // 다음 점검 예정일
  lastInspectedAt DateTime? // 마지막 점검 완료일

  // 정기점검 담당 직원
  assignedStaffId String?
  assignedStaff   OrganizationMember? @relation(fields: [assignedStaffId, organizationId], references: [id, organizationId], onDelete: Restrict)

  isActive Boolean @default(true)
  memo     String?

  serviceRequests ServiceRequest[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([id, organizationId])
  @@index([organizationId])
  @@index([organizationId, rentalContractId])
  @@index([organizationId, nextScheduledAt])
  @@index([organizationId, isActive])
  @@index([assignedStaffId])
}
