model RefreshToken {
  id        String  @id @default(uuid())
  accountId String
  account   Account @relation(fields: [accountId], references: [id], onDelete: Cascade)

  tokenHash String    @unique // 원문 미저장, SHA-256 해시만 보관
  expiresAt DateTime
  revokedAt DateTime? // null = 유효, not null = 무효화됨

  userAgent String? // 기기/브라우저 식별
  ipAddress String? // 로그인 IP

  createdAt DateTime @default(now())

  @@index([accountId])
  @@index([tokenHash])
  @@index([accountId, revokedAt])
}
