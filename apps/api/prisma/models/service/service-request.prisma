model ServiceRequest {
  id String @id @default(uuid())

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Restrict)

  requestNo String

  status ServiceRequestStatus @default(RECEIVED)
  type   ServiceRequestType

  customerId String
  customer   Customer @relation(fields: [customerId, organizationId], references: [id, organizationId], onDelete: Restrict)

  assetId String
  asset   Asset  @relation(fields: [assetId, organizationId], references: [id, organizationId], onDelete: Restrict)

  // 보증기간 내 무상 여부
  isWarranty Boolean @default(false)

  // 증상/접수 내용
  description        String?
  requestedVisitDate DateTime?
  completedAt        DateTime?

  // 방문 위치 (장비 설치 주소와 다를 수 있음)
  visitLocationZonecode      String?
  visitLocationAddress       String?
  visitLocationAddressDetail String?

  maintenanceScheduleId String?
  maintenanceSchedule   MaintenanceSchedule? @relation(fields: [maintenanceScheduleId, organizationId], references: [id, organizationId], onDelete: Restrict)

  memo String?

  visits   ServiceVisit[]
  invoices Invoice[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([id, organizationId])
  @@unique([organizationId, requestNo])
  @@index([organizationId])
  @@index([organizationId, status])
  @@index([organizationId, type])
  @@index([organizationId, customerId])
  @@index([organizationId, assetId])
  @@index([organizationId, maintenanceScheduleId])
}
