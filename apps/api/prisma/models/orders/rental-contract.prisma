model RentalContract {
  id String @id @default(uuid())

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Restrict)

  rentalOrderId String
  rentalOrder   RentalOrder @relation(fields: [rentalOrderId, organizationId], references: [id, organizationId], onDelete: Restrict)

  contractNo String

  status    RentalContractStatus @default(DRAFT)
  isRenewal Boolean              @default(false)

  startDate DateTime
  endDate   DateTime

  contractMonths Int

  // 청구 설정
  billingDay    Int? // 매월 청구 기준일
  paymentDueDay Int? // 매월 납부 기한일
  billingTiming BillingTiming @default(PREPAID)

  createdById String?
  createdBy   OrganizationMember? @relation(fields: [createdById, organizationId], references: [id, organizationId], onDelete: Restrict)

  invoices Invoice[]
  items    RentalContractItem[]
  maintenanceSchedules MaintenanceSchedule[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([id, organizationId])
  @@unique([rentalOrderId, organizationId])
  @@unique([organizationId, contractNo])
  @@index([organizationId])
  @@index([organizationId, status])
  @@index([organizationId, startDate])
  @@index([organizationId, endDate])
}
