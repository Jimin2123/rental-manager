NODE_ENV=development
PORT=3000

POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=rental_manager
POSTGRES_PASSWORD=rental_manager_password
POSTGRES_DB=rental_manager
DB_SSL=false
DB_LOGGING=false
THROTTLE_TTL=60000
THROTTLE_LIMIT=100

DATABASE_URL=postgresql://rental_manager:rental_manager_password@localhost:5432/rental_manager

# JWT
JWT_SECRET=change-me-in-production
JWT_EXPIRES_IN=1h
JWT_REFRESH_EXPIRES_IN=30d
JWT_REFRESH_REMEMBER_EXPIRES_IN=90d

# Mail (Nodemailer / SMTP)
MAIL_HOST=smtp.example.com
MAIL_PORT=587
MAIL_USER=
MAIL_PASS=
MAIL_FROM=noreply@rental-manager.local

# App base URL (used in email links)
APP_URL=http://localhost:3000

# Social login
GOOGLE_CLIENT_ID=
KAKAO_APP_ID=
