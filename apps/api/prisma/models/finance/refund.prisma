model Refund {
  id String @id @default(uuid())

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Restrict)

  refundNo String

  customerId String
  customer   Customer @relation(fields: [customerId, organizationId], references: [id, organizationId], onDelete: Restrict)

  // 청구서 없는 직접 환불(초과 입금 즉시 반환 등)을 허용하기 위해 nullable
  invoiceId String?
  invoice   Invoice? @relation(fields: [invoiceId, organizationId], references: [id, organizationId], onDelete: Restrict)

  // 어떤 입금에서 환불하는지 (없으면 직접 환불)
  paymentId String?
  payment   Payment? @relation(fields: [paymentId, organizationId], references: [id, organizationId], onDelete: Restrict)

  status RefundStatus @default(PENDING)
  reason RefundReason

  // 항상 양수
  amount Int

  method PaymentMethod?

  refundedAt DateTime?

  createdById String?
  createdBy   OrganizationMember? @relation("RefundCreatedBy", fields: [createdById, organizationId], references: [id, organizationId], onDelete: Restrict)

  memo String?

  // 환불 출금한 자사 계좌 (null 허용)
  depositAccountId String?
  depositAccount DepositAccount? @relation(fields: [depositAccountId, organizationId], references: [id, organizationId], onDelete: Restrict)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([id, organizationId])
  @@unique([organizationId, refundNo])
  @@index([organizationId])
  @@index([organizationId, customerId])
  @@index([organizationId, invoiceId])
  @@index([organizationId, paymentId])
  @@index([organizationId, status])
  @@index([organizationId, depositAccountId])
}
